# ============================================================
# .env — Proyecto 2 FHBD
# Variables de entorno para docker-compose
# ============================================================

# Airflow
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_ENDPOINT=http://proyecto2-minio:9000
MINIO_BUCKET_BRONZE=bronze
MINIO_BUCKET_ICEBERG=iceberg

# Nessie
NESSIE_URL=http://proyecto2-nessie:19120/api/v1
NESSIE_BRANCH=main

# Iceberg namespaces
SILVER_NAMESPACE=silver
GOLD_NAMESPACE=gold

# ClickHouse público (fuente StackOverflow)
CH_HOST=play.clickhouse.com
CH_PORT=443
CH_USER=play
CH_PASSWORD=
CH_DB=stackoverflow

# Directorio base del proyecto (dejar vacío = directorio actual)
AIRFLOW_PROJ_DIR=.
