# ============================================================
# .env — Proyecto 2 FHBD
# Variables de entorno para docker-compose
# ============================================================

# Airflow
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# Fija un secret compartido para todos los servicios de Airflow
# (web/scheduler/worker/triggerer). Evita el InvalidSignatureError de JWT
# cuando cada contenedor genera una clave distinta y el worker hace warm shutdown.
AIRFLOW__WEBSERVER__SECRET_KEY=fhbd-proyecto2-airflow-secret-key-9f2c7a1b
AIRFLOW__API__SECRET_KEY=fhbd-proyecto2-airflow-secret-key-9f2c7a1b

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_ENDPOINT=http://proyecto2-minio:9000
MINIO_BUCKET_BRONZE=bronze
MINIO_BUCKET_ICEBERG=iceberg

# Nessie
NESSIE_URL=http://proyecto2-nessie:19120/api/v1
NESSIE_BRANCH=main

# Iceberg namespaces
SILVER_NAMESPACE=silver
GOLD_NAMESPACE=gold

# ClickHouse público (fuente StackOverflow)
CH_HOST=play.clickhouse.com
CH_PORT=443
CH_USER=play
CH_PASSWORD=
CH_DB=stackoverflow

# Directorio base del proyecto (dejar vacío = directorio actual)
AIRFLOW_PROJ_DIR=.
